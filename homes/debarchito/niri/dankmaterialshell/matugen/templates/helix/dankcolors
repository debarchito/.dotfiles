# UI Elements - Background & Basic
"ui.background" = { bg = "background" }
"ui.background.separator" = "outline_variant"
"ui.text" = "on_surface"
"ui.text.focus" = { fg = "on_surface", bg = "surface_container_high" }
"ui.text.inactive" = "outline"
"ui.text.info" = "primary"

# Cursor
"ui.cursor" = { fg = "background", bg = "primary" }
"ui.cursor.primary" = { fg = "background", bg = "primary" }
"ui.cursor.match" = { bg = "secondary", modifiers = ["dim"] }
"ui.cursorline.primary" = { bg = "surface_container" }

# Line Numbers
"ui.linenr" = "outline"
"ui.linenr.selected" = "primary"

# Status Line
"ui.statusline" = { fg = "on_surface", bg = "background" }
"ui.statusline.inactive" = { fg = "outline", bg = "background" }
"ui.statusline.normal" = { fg = "on_surface", bg = "background" }
"ui.statusline.insert" = { fg = "on_surface", bg = "background" }
"ui.statusline.select" = { fg = "on_surface", bg = "background" }

# Buffer Line / Tabs
"ui.bufferline" = { fg = "outline", bg = "background" }
"ui.bufferline.active" = { fg = "on_surface", bg = "surface_container_low", underline = { color = "primary", style = "line" } }
"ui.bufferline.background" = { bg = "background" }

# Popups & Windows
"ui.popup" = { fg = "on_surface", bg = "surface_container" }
"ui.window" = { fg = "outline_variant" }
"ui.help" = { fg = "on_surface", bg = "surface_container_high" }

# Menus
"ui.menu" = { fg = "on_surface", bg = "surface_container" }
"ui.menu.selected" = { fg = "on_primary_container", bg = "primary_container" }
"ui.menu.scroll" = { fg = "outline", bg = "surface_container" }

# Selection
"ui.selection" = { bg = "primary_container" }
"ui.selection.primary" = { bg = "primary_container" }

# Virtual Elements
"ui.virtual.whitespace" = "outline"
"ui.virtual.ruler" = { bg = "surface_container" }
"ui.virtual.indent-guide" = "outline"
"ui.virtual.inlay-hint" = { fg = "outline" }
"ui.virtual.jump-label" = { fg = "primary" }

# Diagnostics
"error" = "error"
"warning" = "tertiary"
"info" = "primary"
"hint" = "outline"
"diagnostic.error" = { underline = { color = "error", style = "curl" } }
"diagnostic.warning" = { underline = { color = "tertiary", style = "curl" } }
"diagnostic.info" = { underline = { color = "primary", style = "curl" } }
"diagnostic.hint" = { underline = { color = "outline", style = "curl" } }

# Diff
"diff.plus" = "secondary"
"diff.minus" = "error"
"diff.delta" = "tertiary"

# Syntax Highlighting - Using dank16 colors

# Comments
"comment" = "outline"
"comment.line" = "outline"
"comment.block" = "outline"
"comment.block.documentation" = "outline"

# Keywords - dank16.color5
"keyword" = "syntax_keyword"
"keyword.control" = "syntax_keyword"
"keyword.control.conditional" = "syntax_keyword"
"keyword.control.repeat" = "syntax_keyword"
"keyword.control.import" = "syntax_keyword"
"keyword.control.return" = "syntax_keyword"
"keyword.control.exception" = "syntax_keyword"
"keyword.operator" = "syntax_keyword"
"keyword.directive" = "syntax_keyword"
"keyword.function" = "syntax_keyword"
"keyword.storage" = "syntax_keyword"
"keyword.storage.type" = "syntax_keyword"
"keyword.storage.modifier" = "syntax_keyword"

# Strings - dank16.color2
"string" = "syntax_string"
"string.regexp" = "syntax_string"
"string.special" = "syntax_string"

# Constants/Numbers - dank16.color12
"constant" = "syntax_constant"
"constant.numeric" = "syntax_constant"
"constant.character" = "syntax_constant"
"constant.character.escape" = "syntax_constant"
"constant.builtin" = "syntax_constant"
"number" = "syntax_constant"
"boolean" = "syntax_constant"
"character" = "syntax_constant"

# Functions - dank16.color4
"function" = "syntax_function"
"function.builtin" = "syntax_function"
"function.method" = "syntax_function"
"function.macro" = "syntax_function"
"function.special" = "syntax_function"
"constructor" = "syntax_function"

# Types - secondary color
"type" = "secondary"
"type.builtin" = "secondary"
"type.enum.variant" = "secondary"
"namespace" = "secondary"
"module" = "secondary"

# Variables
"variable" = "on_surface"
"variable.builtin" = "syntax_constant"
"variable.parameter" = "on_surface"
"variable.other.member" = "syntax_function"
"property" = "syntax_function"

# Operators & Punctuation
"operator" = "on_surface"
"punctuation" = "on_surface"
"punctuation.delimiter" = "on_surface"
"punctuation.bracket" = "on_surface"
"punctuation.special" = "syntax_function"

# Labels & Tags
"label" = "syntax_keyword"
"tag" = "syntax_keyword"
"tag.builtin" = "syntax_keyword"
"attribute" = "syntax_function"

# Special
"special" = "syntax_function"

# Markup (Markdown, etc.)
"markup.heading" = { fg = "primary" }
"markup.heading.marker" = "outline"
"markup.list" = "syntax_keyword"
"markup.list.unnumbered" = "syntax_keyword"
"markup.list.numbered" = "syntax_keyword"
"markup.bold" = "on_surface"
"markup.italic" = "syntax_keyword"
"markup.strikethrough" = { fg = "outline", strikethrough = true }
"markup.link" = "primary"
"markup.link.url" = { fg = "primary", underline = { style = "line" } }
"markup.link.text" = "primary"
"markup.link.label" = "primary"
"markup.quote" = "outline"
"markup.raw" = "syntax_string"
"markup.raw.inline" = "syntax_string"
"markup.raw.block" = "syntax_string"

# Palette definition - Material Design colors + dank16 for syntax
[palette]
# Material Design semantic colors
background = "{{colors.background.default.hex}}"
foreground = "{{colors.on_surface.default.hex}}"
surface_container = "{{colors.surface_container.default.hex}}"
surface_container_low = "{{colors.surface_container_low.default.hex}}"
surface_container_high = "{{colors.surface_container_high.default.hex}}"
on_surface = "{{colors.on_surface.default.hex}}"
primary = "{{colors.primary.default.hex}}"
on_primary = "{{colors.on_primary.default.hex}}"
primary_container = "{{colors.primary_container.default.hex}}"
on_primary_container = "{{colors.on_primary_container.default.hex}}"
secondary = "{{colors.secondary.default.hex}}"
tertiary = "{{colors.tertiary.default.hex}}"
error = "{{colors.error.default.hex}}"
on_error = "{{colors.on_error.default.hex}}"
outline = "{{colors.outline.default.hex}}"
outline_variant = "{{colors.outline_variant.default.hex}}"

# dank16 colors for syntax highlighting
syntax_keyword = "{{dank16.color5.default.hex}}"
syntax_string = "{{dank16.color2.default.hex}}"
syntax_constant = "{{dank16.color12.default.hex}}"
syntax_function = "{{dank16.color4.default.hex}}"
