diff --git a/launcher/LaunchController.cpp b/launcher/LaunchController.cpp
index 8892a5466..f3d61e7fe 100644
--- a/launcher/LaunchController.cpp
+++ b/launcher/LaunchController.cpp
@@ -94,8 +94,7 @@ void LaunchController::decideAccount()
     if (!accounts->anyAccountIsValid()) {
         // Tell the user they need to log in at least one account in order to play.
         auto reply = CustomMessageBox::selectable(m_parentWidget, tr("No Accounts"),
-                                                  tr("In order to play Minecraft, you must have at least one Microsoft "
-                                                     "account which owns Minecraft logged in. "
+                                                  tr("In order to play Minecraft, you must have at least one account (Microsoft or Offline) added. "
                                                      "Would you like to open the account manager to add an account now?"),
                                                   QMessageBox::Information, QMessageBox::Yes | QMessageBox::No)
                          ->exec();
@@ -141,20 +140,12 @@ LaunchDecision LaunchController::decideLaunchMode()
         }
     }
 
-    const auto* accounts = APPLICATION->accounts();
     MinecraftAccountPtr accountToCheck = nullptr;
 
     if (m_accountToUse->accountType() != AccountType::Offline) {
         accountToCheck = m_accountToUse->ownsMinecraft() ? m_accountToUse : nullptr;
-    } else if (const auto defaultAccount = accounts->defaultAccount(); defaultAccount && defaultAccount->ownsMinecraft()) {
-        accountToCheck = defaultAccount;
     } else {
-        for (int i = 0; i < accounts->count(); i++) {
-            if (const auto account = accounts->at(i); account->ownsMinecraft()) {
-                accountToCheck = account;
-                break;
-            }
-        }
+        accountToCheck = m_accountToUse;
     }
 
     if (!accountToCheck) {
diff --git a/launcher/minecraft/auth/MinecraftAccount.h b/launcher/minecraft/auth/MinecraftAccount.h
index 24608701d..9572b945e 100644
--- a/launcher/minecraft/auth/MinecraftAccount.h
+++ b/launcher/minecraft/auth/MinecraftAccount.h
@@ -116,7 +116,7 @@ class MinecraftAccount : public QObject, public Usable {
 
     AccountType accountType() const noexcept { return data.type; }
 
-    bool ownsMinecraft() const { return data.type != AccountType::Offline && data.minecraftEntitlement.ownsMinecraft; }
+    bool ownsMinecraft() const { return data.type == AccountType::Offline || data.minecraftEntitlement.ownsMinecraft; }
 
     bool hasProfile() const { return data.profileId().size() != 0; }
 
diff --git a/launcher/minecraft/launch/LauncherPartLaunch.cpp b/launcher/minecraft/launch/LauncherPartLaunch.cpp
index a2c400e75..71393367d 100644
--- a/launcher/minecraft/launch/LauncherPartLaunch.cpp
+++ b/launcher/minecraft/launch/LauncherPartLaunch.cpp
@@ -43,6 +43,7 @@
 #include "FileSystem.h"
 #include "launch/LaunchTask.h"
 #include "minecraft/MinecraftInstance.h"
+#include <QFile>
 
 #ifdef Q_OS_LINUX
 #include "gamemode_client.h"
@@ -81,6 +82,24 @@ void LauncherPartLaunch::executeTask()
 
     auto instance = m_parent->instance();
 
+    // Disable fullscreen in options.txt if present, to prevent keyboard focus lockup on Wayland
+    QString optionsPath = FS::PathCombine(instance->gameRoot(), "options.txt");
+    if (QFile::exists(optionsPath)) {
+        QFile file(optionsPath);
+        if (file.open(QIODevice::ReadOnly | QIODevice::Text)) {
+            QString content = QString::fromUtf8(file.readAll());
+            file.close();
+            if (content.contains("fullscreen:true")) {
+                content.replace("fullscreen:true", "fullscreen:false");
+                if (file.open(QIODevice::WriteOnly | QIODevice::Text)) {
+                    file.write(content.toUtf8());
+                    file.close();
+                    emit logLine("Auto-disabled fullscreen in options.txt to avoid Wayland keyboard focus issue.", MessageLevel::Launcher);
+                }
+            }
+        }
+    }
+
     QString legacyJarPath;
     if (instance->getLauncher() == "legacy" || instance->shouldApplyOnlineFixes()) {
         legacyJarPath = APPLICATION->getJarPath("NewLaunchLegacy.jar");
